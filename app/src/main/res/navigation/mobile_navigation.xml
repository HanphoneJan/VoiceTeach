        tools:layout="@layout/fragment_music" />
    <fragment
        android:id="@+id/navigation_home"
        android:name="com.yuanchuanshengjiao.voiceteach.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />
    <fragment
        android:id="@+id/navigation_upload"
        android:name="com.yuanchuanshengjiao.voiceteach.ui.upload.UploadFragment"
        android:label="@string/title_upload"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_files"
